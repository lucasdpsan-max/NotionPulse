# ============================================================================
#  NotionPulse — copie este arquivo para .env.local e cole suas chaves.
#  Tudo que ficar como "placeholder" funciona em modo demo/mock.
# ============================================================================

# Banco de dados (SQLite local; Prisma lê via prisma.config.ts)
DATABASE_URL="file:./dev.db"

# Login com Google (Auth.js)
#   Redirect URI no Google Console:
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="placeholder"
AUTH_GOOGLE_SECRET="placeholder"
# Gere com: npx auth secret
AUTH_SECRET="placeholder-secret"

# OpenAI — transcrição de voz (Whisper) e leitura de imagem (vision).
# Sem uma chave real (sk-...), /api/voice e /api/image retornam mock.
OPENAI_API_KEY="placeholder"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Opcionais
STRIPE_SECRET_KEY="placeholder"
STRIPE_WEBHOOK_SECRET="placeholder"
RESEND_API_KEY="placeholder"
