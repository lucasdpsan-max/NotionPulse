# Database (SQLite for local dev — Prisma reads this via prisma.config.ts)
DATABASE_URL="file:./dev.db"

# Auth.js v5
AUTH_SECRET="generate-with: npx auth secret"
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI (voice transcription via Whisper). Without a real key the
# /api/voice endpoint returns a mock transcription so the flow still works.
OPENAI_API_KEY="placeholder"

# Stripe (optional)
STRIPE_SECRET_KEY="placeholder"
STRIPE_WEBHOOK_SECRET="placeholder"

# Resend (optional)
RESEND_API_KEY="placeholder"
